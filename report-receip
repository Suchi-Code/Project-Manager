            margin-top: 20px;
        }
        .form-group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }
        label {
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
            color: #34495e;
        }
        input, select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-family: 'Sarabun', sans-serif;
            font-size: 13px;
        }
        .p-name-custom {
            margin-top: 5px;
            display: none;
        }
        .dynamic-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }
        .dynamic-table th {
            background-color: #34495e;
            color: white;
            padding: 10px 8px;
            font-size: 13px;
        }
        .dynamic-table td {
            padding: 8px 5px;
            border: 1px solid #e0e0e0;
            vertical-align: top;
        }
        .btn {
            background-color: #2ecc71;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Sarabun', sans-serif;
            font-weight: bold;
        }
        .btn-add { background-color: #3498db; font-size: 13px; padding: 6px 12px;}
        .btn-danger { background-color: #e74c3c; font-size: 12px; padding: 5px 10px;}
        .btn-print {
