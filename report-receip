                <td><input type="number" step="0.01" class="p-vat" value="${data ? data.vat : 0}" oninput="updateReport()"></td>
                <td><input type="number" step="0.01" class="p-wh" value="${data ? data.wh : 0}" oninput="updateReport()"></td>
