                </td>
                <td><input type="text" class="p-branch" value="${data ? data.branch : ''}" placeholder="เช่น สำนักงานใหญ่" oninput="updateReport()"></td>
                <td><input type="text" class="p-taxid" pattern="[0-9]*" value="${data ? data.taxid : ''}" placeholder="ตัวเลขเท่านั้น" oninput="this.value = this.value.replace(/[^0-9]/g, ''); updateReport();"></td>
