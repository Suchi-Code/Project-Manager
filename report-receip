            background-color: #white;
            max-width: 210mm;
            margin: 0 auto;
            padding: 10px;
        }
        .page {
            background: white;
            width: 210mm;
            min-height: 297mm;
            box-sizing: border-box;
            padding: 20mm 15mm;
            margin: 0 auto 20px auto;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
